# =============================================================================
# ServiLoc — .env
# =============================================================================
# CE FICHIER EST COMMITÉ dans git — il montre la structure sans les vraies valeurs.
# Copier ce fichier en .env et remplir les valeurs réelles :
#   cp .env .env
#
# Pour générer des secrets sécurisés :
#   INTERNAL_TOKEN  : openssl rand -base64 32
#   JWT_SECRET      : openssl rand -base64 64
#   RSA key pair    : openssl genrsa -out /tmp/jwt_private.pem 2048
#                     openssl rsa -in /tmp/jwt_private.pem -pubout -out /tmp/jwt_public.pem
# =============================================================================

# Eureka
EUREKA_HOSTNAME=localhost

# PostgreSQL — Service Utilisateurs
POSTGRES_USER_DB=db_utilisateurs
POSTGRES_USER_USER=svc_utilisateurs
POSTGRES_USER_PASSWORD=CHANGE_ME

# PostgreSQL — Service Missions
POSTGRES_MISSIONS_DB=db_missions
POSTGRES_MISSIONS_USER=svc_missions
POSTGRES_MISSIONS_PASSWORD=CHANGE_ME

# PostgreSQL — Service Négociations
POSTGRES_NEGO_DB=db_negociations
POSTGRES_NEGO_USER=svc_negociations
POSTGRES_NEGO_PASSWORD=CHANGE_ME

# PostgreSQL — Service Paiement
POSTGRES_PAIEMENT_DB=db_paiement
POSTGRES_PAIEMENT_USER=svc_paiement
POSTGRES_PAIEMENT_PASSWORD=CHANGE_ME

# PostgreSQL — Service Litiges
POSTGRES_LITIGES_DB=db_litiges
POSTGRES_LITIGES_USER=svc_litiges
POSTGRES_LITIGES_PASSWORD=CHANGE_ME

# PostgreSQL — Service Notifications
POSTGRES_NOTIFS_DB=db_notifications
POSTGRES_NOTIFS_USER=svc_notifications
POSTGRES_NOTIFS_PASSWORD=CHANGE_ME

# PostgreSQL — Service Catégories
POSTGRES_CATEGORIES_DB=db_categories
POSTGRES_CATEGORIES_USER=svc_categories
POSTGRES_CATEGORIES_PASSWORD=CHANGE_ME

# PostgreSQL — Service Fichiers
POSTGRES_MEDIA_DB=db_media
POSTGRES_MEDIA_USER=svc_media
POSTGRES_MEDIA_PASSWORD=CHANGE_ME

# RabbitMQ
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=CHANGE_ME
RABBITMQ_VHOST=/

# Redis
REDIS_PASSWORD=CHANGE_ME

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_BUCKET=serviloc-media

# Sécurité
INTERNAL_TOKEN=CHANGE_ME_openssl_rand_base64_32
JWT_SECRET=CHANGE_ME_openssl_rand_base64_64
JWT_PRIVATE_KEY=CHANGE_ME_RSA_PRIVATE_KEY
JWT_PUBLIC_KEY=CHANGE_ME_RSA_PUBLIC_KEY

# APIs externes
SMS_API_KEY=CHANGE_ME
SMS_API_SECRET=CHANGE_ME
SMS_SENDER_ID=ServiLoc
FCM_SERVER_KEY=CHANGE_ME
FCM_PROJECT_ID=CHANGE_ME
MOBILE_MONEY_API_KEY=CHANGE_ME
MOBILE_MONEY_API_SECRET=CHANGE_ME
MOBILE_MONEY_ENV=sandbox
