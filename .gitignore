# =============================================================================
# ServiLoc — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# SECRETS — Ne jamais committer
# -----------------------------------------------------------------------------
.env
*.pem
*.key
*.p12
*.jks
jwt_private.pem
jwt_public.pem

# Fournir .env.example à la place (sans les vraies valeurs)
# .env.example est commité — voir ce fichier pour la structure attendue

# -----------------------------------------------------------------------------
# Maven
# -----------------------------------------------------------------------------
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
*.class

# -----------------------------------------------------------------------------
# Java
# -----------------------------------------------------------------------------
*.jar
*.war
*.ear
*.log

# -----------------------------------------------------------------------------
# IDE — IntelliJ IDEA
# -----------------------------------------------------------------------------
.idea/
*.iws
*.iml
*.ipr
out/
!**/src/main/**/out/
!**/src/test/**/out/

# -----------------------------------------------------------------------------
# IDE — Eclipse
# -----------------------------------------------------------------------------
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# -----------------------------------------------------------------------------
# IDE — VS Code
# -----------------------------------------------------------------------------
.vscode/

# -----------------------------------------------------------------------------
# Docker Compose — Volumes de données (générés localement)
# -----------------------------------------------------------------------------
postgres_data/
rabbitmq_data/
redis_data/
minio_data/

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -----------------------------------------------------------------------------
# Logs applicatifs
# -----------------------------------------------------------------------------
logs/
*.log
spring.log

# -----------------------------------------------------------------------------
# Fichiers temporaires
# -----------------------------------------------------------------------------
*.tmp
*.swp
*.bak
# Fichiers de config locaux avec secrets
**/application-local.yml
**/application-local.properties